    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "return {",
        "\ttienda_nombre: $data.formInput.tienda_nombre,",
        "\tcliente_direccion: $data.formInput.cliente_direccion,",
        "\tproductos: $data.formInput.productos,",
        "\tmontoTotal: $data.formInput.montoTotal",
        "}"
      ],
      "exposed" : false
    },
